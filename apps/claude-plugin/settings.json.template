{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_description": "massa-th0th plugin settings template. Merge the 'hooks' block into your project (.claude/settings.json) or user (~/.claude/settings.json) settings. The five scripts fire-and-forget POST lifecycle observations to the Tools API; they always exit 0 and never block the agent. Set CLAUDE_PLUGIN_ROOT to the repo root, or replace it with an absolute path to apps/claude-plugin.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/user-prompt-submit.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/stop.sh\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/pre-compact.sh\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "mcp__massa-th0th__list_projects",
      "mcp__massa-th0th__project_map",
      "mcp__massa-th0th__index_status",
      "mcp__massa-th0th__analytics",
      "mcp__massa-th0th__search",
      "mcp__massa-th0th__search_definitions",
      "mcp__massa-th0th__go_to_definition",
      "mcp__massa-th0th__get_references"
    ]
  }
}
